// ActivityType — 31 values after Sprint 6 M1 (27 existing + 4 Instagram).
// Shape of each type's metadata field is defined by ActivityMetadata discriminated union
// in packages/shared/src/types/activity-metadata.ts. All eventBus.emit() sites must use
// constants from packages/shared/src/constants/events.ts — no inline string literals.
enum ActivityType {
  LEAD_CREATED
  LEAD_STATUS_CHANGED
  LEAD_ASSIGNED
  LEAD_WON
  LEAD_LOST
  CONTACT_CREATED
  CONTACT_UPDATED
  TASK_CREATED
  TASK_COMPLETED
  TASK_CANCELLED
  NOTE_ADDED
  NOTE_UPDATED
  NOTE_DELETED
  FILE_UPLOADED
  FILE_DELETED
  DEAL_CREATED
  DEAL_STAGE_MOVED
  DEAL_WON
  DEAL_LOST
  // Sprint 5 M1 additions
  DEAL_UPDATED
  PIPELINE_CREATED
  PIPELINE_UPDATED
  PIPELINE_DELETED
  PIPELINE_STAGE_CREATED
  PIPELINE_STAGE_UPDATED
  PIPELINE_STAGE_DELETED
  PIPELINE_STAGE_REORDERED
  // Sprint 6 M1 additions — Instagram Inbox
  MESSAGE_RECEIVED
  MESSAGE_SENT
  INSTAGRAM_ACCOUNT_CONNECTED
  INSTAGRAM_ACCOUNT_DISCONNECTED
}

// MessageDirection already in enums.ts; parity-checked against this declaration.
enum MessageDirection {
  INBOUND
  OUTBOUND
}

// Sprint 6 M1 — Instagram Inbox enums
enum InstagramAccountStatus {
  ACTIVE
  EXPIRED
  DISCONNECTED
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

// Sprint 4 — custom field enums (FR-LEAD-009)
enum CustomFieldObjectType {
  LEAD
  CONTACT
  DEAL
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTI_SELECT
  BOOLEAN
  URL
}

enum StorageProvider {
  S3
  CLOUDINARY
}

// Prisma-only enum (not in shared; used by verification_tokens). Not parity-checked.
enum VerificationTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ============================================================================
// IDENTITY & ORGANIZATION MODELS (Sprint 2)
// ============================================================================

model User {
  id               String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email            String     @unique
  passwordHash     String
  firstName        String
  lastName         String
  avatarUrl        String?
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  failedLoginCount Int        @default(0)
  lockedUntil      DateTime?
  isSuperAdmin     Boolean    @default(false)
  status           UserStatus @default(ACTIVE)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  deletedAt        DateTime?

  memberships        OrganizationMember[]
  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]
  // Sprint 4 CRM relations
  assignedLeads           Lead[]                  @relation("LeadAssignee")
  createdLeads            Lead[]                  @relation("LeadCreator")
  assignedContacts        Contact[]               @relation("ContactAssignee")
  createdContacts         Contact[]               @relation("ContactCreator")
  assignedTasks           Task[]                  @relation("TaskAssignee")
  createdTasks            Task[]                  @relation("TaskCreator")
  performedActivities     Activity[]              @relation("ActivityPerformer")
  createdNotes            Note[]                  @relation("NoteCreator")
  uploadedFiles           File[]                  @relation("FileUploader")
  teamInvitesSent         TeamInvite[]            @relation("InviteSender")
  customFieldDefinitions  CustomFieldDefinition[] @relation("CustomFieldCreator")
  savedReplies            SavedReply[]            @relation("SavedReplyCreator")
  // Sprint 5 Deal relations
  assignedDeals           Deal[]                  @relation("DealAssignee")
  createdDeals            Deal[]                  @relation("DealCreator")
  // Sprint 6 Instagram Inbox relations
  assignedConversations   InstagramConversation[] @relation("ConversationAssignee")

  @@index([status])
  @@map("users")
}

model Organization {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String
  slug          String    @unique
  industry      String?
  logoUrl       String?
  timezone      String    @default("Asia/Kolkata")
  currency      String    @default("INR")
  language      String    @default("en")
  businessHours Json?
  status        OrgStatus @default(ACTIVE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  members      OrganizationMember[]
  roles        Role[]
  subscription Subscription?
  // Sprint 4 CRM relations
  leads                  Lead[]
  contacts               Contact[]
  tasks                  Task[]
  activities             Activity[]
  notes                  Note[]
  files                  File[]
  aiScores               AiScore[]
  customFieldDefinitions CustomFieldDefinition[]
  teamInvites            TeamInvite[]
  savedReplies           SavedReply[]
  // Sprint 5 Pipeline & Deal relations
  pipelines              Pipeline[]
  pipelineStages         PipelineStage[]
  deals                  Deal[]
  webhookEvents          WebhookEvent[]
  // Sprint 6 Instagram Inbox relations
  instagramAccounts      InstagramAccount[]
  instagramConversations InstagramConversation[]
  messages               Message[]

  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String       @db.Uuid
  userId         String       @db.Uuid
  roleId         String       @db.Uuid
  status         MemberStatus @default(ACTIVE)
  invitedById    String?      @db.Uuid
  invitedAt      DateTime?
  joinedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([status])
  @@map("organization_members")
}

model Role {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  name           String
  isSystem       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id])
  permissions  Permission[]
  members      OrganizationMember[]
  teamInvites  TeamInvite[]

  @@unique([organizationId, name])
  @@map("roles")
}

model Permission {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roleId    String   @db.Uuid
  resource  String
  action    String
  createdAt DateTime @default(now())

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("permissions")
}

model RefreshToken {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String    @db.Uuid
  organizationId String    @db.Uuid
  tokenHash      String    @unique
  family         String    @db.Uuid
  deviceInfo     String?
  ipAddress      String?
  expiresAt      DateTime
  usedAt         DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, family])
  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model VerificationToken {
  id        String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String                @db.Uuid
  type      VerificationTokenType
  tokenHash String                @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, type])
  @@map("verification_tokens")
}

// Sprint 2 creates only the TRIAL row at org bootstrap. Stripe fields + reconciliation
// columns are exercised by the Billing module (S8).
model Subscription {
  id                   String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId       String             @unique @db.Uuid
  plan                 SubscriptionPlan   @default(TRIAL)
  status               SubscriptionStatus @default(TRIALING)
  trialEndsAt          DateTime?
  seatCount            Int                @default(1)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  // P0-6: required for Stripe webhook idempotency and reconciliation (FINAL_ARCHITECTURE.md §4.4)
  lastStripeEventAt    DateTime?
  lastSyncedAt         DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("subscriptions")
}

// Sprint 3 M5 (AUD-1) — tenant-scoped, append-only audit trail.
model AuditLog {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  actorUserId    String?  @db.Uuid
  action         String
  resource       String
  resourceId     String?
  before         Json?
  after          Json?
  ipAddress      String?  @db.VarChar(64)
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

// Sprint 3 M5 (AUD-3) — platform/super-admin audit trail SCAFFOLD.
model PlatformAuditLog {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actorUserId          String?  @db.Uuid
  action               String
  targetOrganizationId String?  @db.Uuid
  targetResource       String?
  detail               Json?
  ipAddress            String?  @db.VarChar(64)
  createdAt            DateTime @default(now())

  @@index([createdAt])
  @@map("platform_audit_logs")
}

// ============================================================================
// SPRINT 4 — CRM MODELS
// ============================================================================

// Lead — highest fan-in model in the system.
// INVARIANTS enforced at DB layer (migration 0007_crm_tables):
//   • leads_source_immutable trigger: source cannot change after creation
//   • WON status only reachable via convert() — rejected on direct PATCH
//   • pipelineStageId: plain UUID (no FK in Sprint 4 — FK added in Sprint 5 migration)
//   • instagramAccountId: plain UUID (no FK in Sprint 4 — FK added in Sprint 6 migration)
//   • mergedIntoLeadId: plain UUID (no FK in Sprint 4 — FK added in merge milestone)
model Lead {
  id                   String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId       String     @db.Uuid
  firstName            String     @db.VarChar(100)
  lastName             String?    @db.VarChar(100)
  email                String?    @db.VarChar(255)
  phone                String?    @db.VarChar(20)
  source               LeadSource @default(MANUAL)
  status               LeadStatus @default(NEW)
  assignedToId         String?    @db.Uuid
  aiScore              Int?       @db.SmallInt
  aiScoreUpdatedAt     DateTime?
  instagramHandle      String?    @db.VarChar(100)
  instagramUserId      String?    @db.VarChar(50)
  instagramAccountId   String?    @db.Uuid // deferred FK → instagram_accounts (Sprint 6)
  tags                 String[]   @default([])
  customFields         Json       @default("{}")
  lostReason           String?    @db.Text
  convertedToContactId String?    @db.Uuid
  pipelineStageId      String?    @db.Uuid // deferred FK → pipeline_stages (Sprint 5)
  mergedIntoLeadId     String?    @db.Uuid // deferred self-ref FK (merge milestone)
  lastActivityAt       DateTime?
  createdById          String     @db.Uuid
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  deletedAt            DateTime?

  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo         User?        @relation("LeadAssignee", fields: [assignedToId], references: [id])
  createdBy          User         @relation("LeadCreator", fields: [createdById], references: [id])
  // convertedToContactId FK: Lead stores which contact it converted into (many-to-one; 1 in practice)
  convertedToContact Contact?     @relation("LeadToContact", fields: [convertedToContactId], references: [id])
  // Back-ref for Contact.createdFromLeadId: contacts that were created from this lead
  createdContacts    Contact[]    @relation("ContactFromLead")
  activities         Activity[]
  tasks              Task[]
  notesList          Note[]
  files              File[]
  aiScores           AiScore[]
  deals              Deal[]
  // Sprint 6 Instagram Inbox relations
  instagramConversations InstagramConversation[]
  instagramAccount       InstagramAccount?       @relation(fields: [instagramAccountId], references: [id])

  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@index([organizationId, source])
  @@index([organizationId, aiScore(sort: Desc)])
  @@index([organizationId, lastActivityAt(sort: Desc)])
  @@index([email])
  @@index([phone])
  @@index([instagramUserId])
  // @@unique enforced here for TypeScript upsert API; DB index created CONCURRENTLY in migration 0015b
  @@unique([organizationId, instagramUserId])
  @@index([deletedAt])
  @@map("leads")
}

model Contact {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId    String    @db.Uuid
  firstName         String    @db.VarChar(100)
  lastName          String?   @db.VarChar(100)
  email             String?   @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  company           String?   @db.VarChar(255)
  jobTitle          String?   @db.VarChar(100)
  avatarUrl         String?   @db.Text
  address           Json?
  tags              String[]  @default([])
  customFields      Json      @default("{}")
  lifeTimeValue     Decimal   @default(0) @db.Decimal(15, 2)
  assignedToId      String?   @db.Uuid
  lastActivityAt    DateTime?
  createdFromLeadId String?   @db.Uuid
  createdById       String    @db.Uuid
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo      User?        @relation("ContactAssignee", fields: [assignedToId], references: [id])
  createdBy       User         @relation("ContactCreator", fields: [createdById], references: [id])
  // createdFromLeadId FK: Contact tracks which lead it was created from (many-to-one; 1 in practice)
  createdFromLead Lead?        @relation("ContactFromLead", fields: [createdFromLeadId], references: [id])
  // Back-ref for Lead.convertedToContactId: leads that converted into this contact
  convertedLeads  Lead[]       @relation("LeadToContact")
  activities      Activity[]
  tasks           Task[]
  notesList       Note[]
  files           File[]
  deals           Deal[]
  // Sprint 6 Instagram Inbox relations
  instagramConversations InstagramConversation[]

  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@index([organizationId, assignedToId])
  @@index([organizationId, createdFromLeadId])
  @@index([organizationId, lastActivityAt(sort: Desc)])
  @@index([deletedAt])
  @@map("contacts")
}

model Task {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String       @db.Uuid
  title            String       @db.VarChar(255)
  description      String?      @db.Text
  type             TaskType     @default(OTHER)
  priority         TaskPriority @default(MEDIUM)
  status           TaskStatus   @default(PENDING)
  dueDate          DateTime?
  completedAt      DateTime?
  assignedToId     String?      @db.Uuid
  relatedLeadId    String?      @db.Uuid
  relatedDealId    String?      @db.Uuid
  relatedContactId String?      @db.Uuid
  createdById      String       @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedTo     User?        @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdBy      User         @relation("TaskCreator", fields: [createdById], references: [id])
  relatedLead    Lead?        @relation(fields: [relatedLeadId], references: [id])
  relatedContact Contact?     @relation(fields: [relatedContactId], references: [id])
  relatedDeal    Deal?        @relation("TaskDeal", fields: [relatedDealId], references: [id])

  @@index([organizationId, assignedToId, status])
  @@index([organizationId, dueDate, status])
  @@index([organizationId, relatedLeadId])
  @@index([deletedAt])
  @@map("tasks")
}

// Activity — append-only immutable log. PARTITIONED BY RANGE(createdAt) in the DB.
// ⚠ PARTITION PK: Postgres requires the partition key in the PK.
// The migration (0007_crm_tables) uses PRIMARY KEY (id, "createdAt") — NOT PRIMARY KEY (id).
// Prisma @id on `id` is used for TypeScript types only; actual DB PK is composite.
// This table's DDL is hand-authored; do NOT run prisma migrate dev to regenerate it.
// DB triggers enforce immutability: activities_no_update, activities_no_delete.
model Activity {
  id               String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String       @db.Uuid
  type             ActivityType
  description      String       @db.Text
  metadata         Json         @default("{}")
  performedById    String?      @db.Uuid
  relatedLeadId    String?      @db.Uuid
  relatedDealId    String?      @db.Uuid
  relatedContactId String?      @db.Uuid
  relatedPipelineId      String? @db.Uuid
  relatedPipelineStageId String? @db.Uuid
  createdAt        DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  performedBy    User?        @relation("ActivityPerformer", fields: [performedById], references: [id])
  relatedLead    Lead?        @relation(fields: [relatedLeadId], references: [id])
  relatedContact Contact?     @relation(fields: [relatedContactId], references: [id])
  relatedDeal    Deal?        @relation("ActivityDeal", fields: [relatedDealId], references: [id])

  // NO updatedAt — activities are immutable
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, relatedLeadId, createdAt(sort: Desc)])
  @@index([organizationId, relatedContactId, createdAt(sort: Desc)])
  @@index([organizationId, relatedPipelineId, createdAt(sort: Desc)])
  @@index([organizationId, relatedPipelineStageId, createdAt(sort: Desc)])
  @@map("activities")
}

// Note — content stored as ProseMirror/Tiptap JSON (JSONB). Never render as raw HTML.
// For workflow/email interpolation call toPlainText(content).
model Note {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String    @db.Uuid
  content          Json      @default("{}")
  relatedLeadId    String?   @db.Uuid
  relatedDealId    String?   @db.Uuid
  relatedContactId String?   @db.Uuid
  createdById      String    @db.Uuid
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("NoteCreator", fields: [createdById], references: [id])
  relatedLead    Lead?        @relation(fields: [relatedLeadId], references: [id])
  relatedContact Contact?     @relation(fields: [relatedContactId], references: [id])
  relatedDeal    Deal?        @relation("NoteDeal", fields: [relatedDealId], references: [id])

  @@index([organizationId, relatedLeadId])
  @@index([organizationId, relatedContactId])
  @@map("notes")
}

model File {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String          @db.Uuid
  name             String          @db.VarChar(255)
  storageKey       String          @db.Text
  storageProvider  StorageProvider
  mimeType         String          @db.VarChar(100)
  sizeBytes        BigInt
  url              String          @db.Text
  relatedLeadId    String?         @db.Uuid
  relatedDealId    String?         @db.Uuid
  relatedContactId String?         @db.Uuid
  uploadedById     String          @db.Uuid
  createdAt        DateTime        @default(now())
  deletedAt        DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy     User         @relation("FileUploader", fields: [uploadedById], references: [id])
  relatedLead    Lead?        @relation(fields: [relatedLeadId], references: [id])
  relatedContact Contact?     @relation(fields: [relatedContactId], references: [id])
  relatedDeal    Deal?        @relation("FileDeal", fields: [relatedDealId], references: [id])

  @@index([organizationId, relatedLeadId])
  @@index([organizationId, relatedContactId])
  @@map("files")
}

// Structured AI scoring output. leads.aiScore/aiScoreUpdatedAt are denormalized read cache.
// This table holds full history, confidence, factors, and recommendation. Sprint 7 writes here.
// Immutable: no updatedAt, no deletedAt.
model AiScore {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  leadId         String   @db.Uuid
  score          Int      @db.SmallInt
  confidence     Decimal? @db.Decimal(3, 2)
  factors        Json?
  recommendation String?  @db.Text
  triggeredBy    String?  @db.VarChar(50)
  modelVersion   String?  @db.VarChar(50)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([organizationId, leadId, createdAt(sort: Desc)])
  @@index([organizationId, score])
  @@map("ai_scores")
}

// Schema table for org-defined custom fields (FR-LEAD-009).
// ⚠ UNIQUENESS: enforced via a PARTIAL unique index (WHERE deletedAt IS NULL) hand-authored
// in migration 0007_crm_tables — NOT via @@unique. A @@unique block generates a non-partial
// constraint that prevents re-using a field key after soft-delete.
// Custom migration SQL: CREATE UNIQUE INDEX ... WHERE "deletedAt" IS NULL
model CustomFieldDefinition {
  id             String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String                @db.Uuid
  objectType     CustomFieldObjectType
  fieldKey       String                @db.VarChar(100)
  displayLabel   String                @db.VarChar(100)
  fieldType      CustomFieldType
  options        Json?
  isRequired     Boolean               @default(false)
  position       Int                   @db.SmallInt
  createdById    String                @db.Uuid
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("CustomFieldCreator", fields: [createdById], references: [id])

  // @@unique intentionally absent — partial unique index hand-authored in 0007_crm_tables
  @@index([organizationId, objectType, deletedAt])
  @@map("custom_field_definitions")
}

// Token store for email invite links (magic link, 7-day expiry).
// Token validation (on link click) uses admin prisma client — D-M3-2 boundary.
// Organization member INSERT after acceptance uses withTenant.
model TeamInvite {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String    @db.Uuid
  email          String    @db.VarChar(255)
  roleId         String    @db.Uuid
  tokenHash      String    @unique @db.VarChar(255)
  invitedById    String    @db.Uuid
  expiresAt      DateTime
  acceptedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  invitedBy    User         @relation("InviteSender", fields: [invitedById], references: [id])

  @@index([organizationId, email])
  @@map("team_invites")
}

// Saved reply templates for the inbox (FR-INBOX-006).
// Shell table only in Sprint 4 — no routes or service code.
// Routes and CRUD added in Sprint 6 (Inbox module).
model SavedReply {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String    @db.Uuid
  title          String    @db.VarChar(255)
  content        String    @db.Text
  shortcut       String?   @db.VarChar(50)
  isGlobal       Boolean   @default(true)
  createdById    String    @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("SavedReplyCreator", fields: [createdById], references: [id])

  @@index([organizationId, deletedAt])
  @@map("saved_replies")
}

// ============================================================================
// SPRINT 5 M1 — PIPELINE & DEALS + WEBHOOK FOUNDATION
// ============================================================================

// Sales pipeline definition. One org can have multiple pipelines (plan-gated: TRIAL/STARTER = 1).
// Exactly one pipeline per org has isDefault = true — enforced by partial unique index in migration.
model Pipeline {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  name           String   @db.VarChar(100)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  deals        Deal[]

  @@index([organizationId])
  @@map("pipelines")
}

// Stage within a pipeline. Ordered by `order` ASC (0-based). Each pipeline must have
// exactly one isWon stage and exactly one isLost stage — enforced at the service layer.
model PipelineStage {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String   @db.Uuid
  pipelineId     String   @db.Uuid
  name           String   @db.VarChar(100)
  order          Int
  color          String?  @db.VarChar(7)
  probability    Int?
  isWon          Boolean  @default(false)
  isLost         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline     @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals        Deal[]

  @@index([organizationId, pipelineId])
  @@index([pipelineId, order])
  @@map("pipeline_stages")
}

// Opportunity (deal) linked to a pipeline stage. Optionally associated with a lead/contact.
// Status machine: OPEN → WON or OPEN → LOST (terminal; no reopen in V1).
// Soft-deleted via deletedAt. value in INR by default (currency field stores ISO 4217 code).
model Deal {
  id                 String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId     String     @db.Uuid
  title              String     @db.VarChar(200)
  value              Decimal?   @db.Decimal(15, 2)
  currency           String     @default("INR") @db.Char(3)
  pipelineId         String     @db.Uuid
  stageId            String     @db.Uuid
  leadId             String?    @db.Uuid
  contactId          String?    @db.Uuid
  assignedToId       String?    @db.Uuid
  createdById        String     @db.Uuid
  status             DealStatus @default(OPEN)
  closedAt           DateTime?
  lostReason         String?    @db.VarChar(500)
  expectedCloseDate  DateTime?
  customFields       Json       @default("{}")
  deletedAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  stage        PipelineStage @relation(fields: [stageId], references: [id], onDelete: Restrict)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact      Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo   User?         @relation("DealAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy    User          @relation("DealCreator", fields: [createdById], references: [id], onDelete: Restrict)
  tasks        Task[]        @relation("TaskDeal")
  notes        Note[]        @relation("NoteDeal")
  files        File[]        @relation("FileDeal")
  activities   Activity[]    @relation("ActivityDeal")

  @@index([organizationId, status, stageId])
  @@index([organizationId, pipelineId])
  @@index([leadId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("deals")
}

// Inbound webhook event store. persist-then-200: row is written before returning 200 to the source.
// organizationId is nullable — Stripe events arrive before org resolution; worker back-fills it.
// Idempotency: UNIQUE(source, externalEventId) — duplicate deliveries skip re-enqueue.
// Status transitions: PENDING → PROCESSING → DONE | FAILED | SKIPPED.
model WebhookEvent {
  id              String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId  String?            @db.Uuid
  source          WebhookSource
  externalEventId String
  payload         Json
  rawHeaders      Json               @default("{}")
  status          WebhookEventStatus @default(PENDING)
  attempts        Int                @default(0)
  lastAttemptAt   DateTime?
  processedAt     DateTime?
  errorMessage    String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([source, externalEventId])
  @@index([status, createdAt])
  @@map("webhook_events")
}

// ============================================================================
// SPRINT 6 M1 — INSTAGRAM INBOX MODELS
// ============================================================================

// Connected Instagram account (business IG account or Page).
// accessToken is AES-256-GCM encrypted; stored as v{n}:{hex(iv)}:{hex(tag)}:{hex(ct)}.
// instagramAccountId on Lead has a deferred FK added in migration 0016.
model InstagramAccount {
  id                  String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId      String                 @db.Uuid
  igUserId            String                 @db.VarChar(50)
  igUsername          String?                @db.VarChar(100)
  accessToken         String                 @db.Text
  tokenExpiresAt      DateTime               @db.Timestamptz
  tokenType           String                 @db.VarChar(20)
  status              InstagramAccountStatus @default(ACTIVE)
  webhookSubscribed   Boolean                @default(false)
  profilePictureUrl   String?                @db.Text
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  deletedAt           DateTime?

  organization           Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations          InstagramConversation[]
  leads                  Lead[]

  @@unique([organizationId, igUserId])
  @@index([organizationId, status])
  @@index([igUserId])
  @@map("instagram_accounts")
}

// An Instagram DM conversation thread between the org's IG account and a contact.
// igConversationId is Meta's thread identifier (unique per org IG account pair).
model InstagramConversation {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId   String             @db.Uuid
  igConversationId String             @db.VarChar(100)
  igAccountId      String             @db.Uuid
  leadId           String?            @db.Uuid
  contactId        String?            @db.Uuid
  assignedToId     String?            @db.Uuid
  status           ConversationStatus @default(OPEN)
  labels           Json               @default("[]")
  firstResponseAt  DateTime?          @db.Timestamptz
  lastInboundAt    DateTime?          @db.Timestamptz
  lastMessageAt    DateTime?          @db.Timestamptz
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  igAccount    InstagramAccount @relation(fields: [igAccountId], references: [id], onDelete: Cascade)
  lead         Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact      Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo   User?           @relation("ConversationAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages     Message[]

  @@unique([organizationId, igConversationId])
  @@index([organizationId, status, lastMessageAt(sort: Desc)])
  @@index([organizationId, assignedToId])
  @@index([leadId])
  @@index([igAccountId])
  @@map("instagram_conversations")
}

// Individual DM message within an Instagram conversation.
// mid is Meta's globally unique message ID — used as the idempotency key.
model Message {
  id             String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organizationId String            @db.Uuid
  conversationId String            @db.Uuid
  mid            String            @unique @db.VarChar(200)
  direction      MessageDirection
  contentType    String            @default("TEXT") @db.VarChar(20)
  content        Json
  status         MessageStatus     @default(SENT)
  sentAt         DateTime          @db.Timestamptz
  deliveredAt    DateTime?         @db.Timestamptz
  readAt         DateTime?         @db.Timestamptz
  senderId       String?           @db.VarChar(100)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation InstagramConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, sentAt(sort: Desc)])
  @@index([organizationId, direction, status])
  @@map("messages")
}
