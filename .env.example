# LeadOS environment variables (documented names only — NEVER commit real values).
# Production secrets live in AWS Secrets Manager (FINAL_ARCHITECTURE.md §6.5 / doc 19).
# Sprint 1 uses only the subset required for the platform spine; the rest are
# documented here so the contract is established early.

# ---------------------------------------------------------------------------
# Backend / Worker (apps/api)
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
APP_WEB_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# Database (Neon) — pooled (transaction mode) + direct (migrations) + read replica
DATABASE_URL=postgresql://leados:leados@localhost:5432/leados?schema=public
DATABASE_DIRECT_URL=postgresql://leados:leados@localhost:5432/leados?schema=public
DATABASE_REPLICA_URL=postgresql://leados:leados@localhost:5432/leados?schema=public

# Redis (Upstash in prod) — used for cache, queues, rate-limit, pub/sub
REDIS_URL=redis://localhost:6379

# Observability (optional in dev; guarded — absent = disabled)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
GIT_SHA=local

# --- The following are NOT used in Sprint 1; documented for the contract. ---
# Auth (S2)
JWT_ACCESS_SECRET=
JWT_REFRESH_PEPPER=
# Field encryption (S6) — OAuth tokens only
FIELD_ENCRYPTION_KEY=
FIELD_ENCRYPTION_KEY_VERSION=1
# Instagram (S6)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_GRAPH_VERSION=
# WhatsApp (V2)
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
# AI (S7)
OPENAI_API_KEY=
# Billing (S8)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=
# Email (S2)
SENDGRID_API_KEY=
SENDGRID_FROM_DOMAIN=
# Storage (S4)
CLOUDINARY_URL=
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Frontend (apps/web)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=development
API_INTERNAL_URL=http://localhost:4000
SESSION_COOKIE_DOMAIN=localhost
STRIPE_PUBLISHABLE_KEY=
