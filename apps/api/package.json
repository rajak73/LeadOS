{
  "name": "@leados/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "prisma generate --schema=../../prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=../../prisma/schema.prisma",
    "db:migrate:create": "prisma migrate dev --schema=../../prisma/schema.prisma",
    "db:seed": "tsx ../../prisma/seed/index.ts",
    "db:studio": "prisma studio --schema=../../prisma/schema.prisma",
    "check:rls": "tsx scripts/check-rls-coverage.ts",
    "bench:tenancy": "tsx scripts/tenancy-bench.ts"
  },
  "dependencies": {
    "@leados/shared": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@prisma/client": "^5.21.0",
    "@sentry/node": "^8.35.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.21.0",
    "cookie-parser": "^1.4.7",
    "jsonwebtoken": "^9.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^5.0.4",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@leados/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.5",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.13.0",
    "prisma": "^5.21.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
