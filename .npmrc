# The Prisma schema lives at the repo root (prisma/schema.prisma) but @prisma/client and the
# prisma CLI are dependencies of apps/api. Hoist the Prisma packages to the root node_modules
# so `prisma generate` (which resolves @prisma/client relative to the schema location) finds
# them, and so apps/api resolves the generated client. This avoids Prisma's CLI auto-install.
public-hoist-pattern[]=*prisma*
public-hoist-pattern[]=@prisma/*
